# App Configuration
APP_NAME="AI Note Assistant"
DEBUG=True
SECRET_KEY="your-super-secret-key-change-this-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database Configuration (PostgreSQL 17)
DATABASE_URL="postgresql+asyncpg://postgres:password@localhost:5432/note_assistant_db"

# Google OAuth2 Configuration
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:8000/auth/google/callback"

# SMTP Configuration (Brevo)
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT=587
SMTP_USER="your-brevo-username"
SMTP_PASSWORD="your-brevo-api-key"
EMAILS_FROM_EMAIL="noreply@assistant.app"
EMAILS_FROM_NAME="AI Note Assistant"

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# AI Model Configuration (Groq)
GROQ_API_KEY="your-groq-api-key"
LLM_MODEL_NAME="llama-3.3-70b-versatile"
LLM_BASE_URL="https://api.groq.com/openai/v1"

# Frontend Configuration
FRONTEND_URL="http://localhost:3000"
